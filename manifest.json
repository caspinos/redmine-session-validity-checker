{
  "manifest_version": 3,
  "name": "Redmine Session Validity Checker",
  "version": "1.0.0",
  "description": "A cross-browser extension that monitors Redmine sessions and warns users when their session expires to prevent data loss.",
  "default_locale": "en",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
	"service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
	  "gecko": {
		"id": "{29533187-a19f-41fd-9c57-d52899cc0c9a}",
		"data_collection_permissions": {
        	"required": ["none"]
      	}
	  }
  }
}
